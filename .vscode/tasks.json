{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Pacman",
            "type": "shell",
            "command": "C:\\msys64\\clang64\\bin\\clang++.exe",
            "args": [
                "-std=c++17",
                "-Wall",
                "-Wextra",
                "-pedantic",
                "-O0",
                "-g",
                "-fno-omit-frame-pointer",
                "-fsanitize=address",
                "-fsanitize=undefined",
                "main.cpp",
                "provaPacman.cpp",
                "-o",
                "main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}